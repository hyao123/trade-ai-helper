# 复制此文件为 .env 并填入真实值
# Copy this file to .env and fill in your values

# Kimi API Key（必填）
# Get your key at: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# 应用访问密码（留空则不启用鉴权，适合本地开发）
# Leave empty to disable auth (good for local dev)
APP_PASSWORD=

# Rate Limiting 配置（可选，默认：每小时最多20次）
# Optional rate limiting config (defaults: 20 calls per hour)
RATE_LIMIT_MAX_CALLS=20
RATE_LIMIT_WINDOW=3600
