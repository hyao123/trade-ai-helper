# 复制此文件为 .env 并填入真实值
# Copy this file to .env and fill in your values

# NVIDIA NIM API Key（必填）
# 获取地址：https://build.nvidia.com → 选任意模型 → Get API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用的模型（可选，默认 meta/llama-3.3-70b-instruct）
# 其他可选：mistralai/mistral-large-2-instruct, google/gemma-3-27b-it
# 完整列表：https://build.nvidia.com/models
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# 应用访问密码（留空则不启用鉴权，适合本地开发）
APP_PASSWORD=

# Rate Limiting 配置（可选，默认：每小时最多20次）
RATE_LIMIT_MAX_CALLS=20
RATE_LIMIT_WINDOW=3600

# SMTP Email Configuration (optional, for email verification)
# If not configured, registration still works but verification emails won't be sent
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com

# Stripe Payment (for tier upgrades)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_PRICE_ID_PRO=your_stripe_pro_price_id_here
STRIPE_PRICE_ID_ENTERPRISE=your_stripe_enterprise_price_id_here

# App Base URL (used for Stripe redirect URLs, defaults to https://localhost:8501)
APP_BASE_URL=https://your-app.streamlit.app
