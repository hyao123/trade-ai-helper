# 复制此文件为 secrets.toml（本地开发用）
# Streamlit Cloud 部署时，在 App Settings → Secrets 中填写以下内容
#
# [注意] 不要将真实的 secrets.toml 提交到 Git！已在 .gitignore 中排除

KIMI_API_KEY = "your_kimi_api_key_here"

# 可选：设置访问密码，防止他人消耗你的 API 额度
# 留空则不启用鉴权
APP_PASSWORD = ""

# 可选：调整限速（默认每小时20次）
# RATE_LIMIT_MAX_CALLS = "20"
# RATE_LIMIT_WINDOW = "3600"
