# Streamlit Cloud 部署时，在 App Settings → Secrets 中粘贴以下内容
# 本地开发可复制为 .streamlit/secrets.toml（已在 .gitignore 中排除）
#
# NVIDIA API Key 获取：https://build.nvidia.com → 选任意模型 → Get API Key

NVIDIA_API_KEY = "nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 使用的模型（可选，默认 meta/llama-3.3-70b-instruct）
# NVIDIA_MODEL = "meta/llama-3.3-70b-instruct"

# 访问密码（留空则不启用）
APP_PASSWORD = ""

# Rate Limiting（可选）
# RATE_LIMIT_MAX_CALLS = "20"
# RATE_LIMIT_WINDOW = "3600"
